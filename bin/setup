#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)
FRONTEND_ROOT = File.join(APP_ROOT, "frontend")

def system!(*args)
  system(*args, exception: true)
end

def command_exists?(cmd)
  system("which #{cmd} > /dev/null 2>&1")
end

FileUtils.chdir APP_ROOT do
  puts "== Rails + React Development Setup =="

  puts "== Checking for required commands =="
  puts "== Installing dependencies for the Dispute =="
  system("bundle check") || system!("bundle install")

  puts "\n== Checking Node & npm =="
  abort "Node.js is not installed. Install Node.js first." unless command_exists?("node")
  abort "npm is not installed. Install npm first." unless command_exists?("npm")

  puts "\n== Installing frontend JavaScript packages =="
  if Dir.exist?(FRONTEND_ROOT)
    FileUtils.chdir FRONTEND_ROOT do
      system!("npm install")
    end
  else
    abort "frontend/ directory not found"
  end

  puts "\n== Copying sample files =="
  unless File.exist?("config/database.yml")
    FileUtils.cp "config/database.yml.sample", "config/database.yml"
  end

  puts "\n== Preparing database =="
  system! "bin/rails db:prepare"
  system! "bin/rails db:reset" if ARGV.include?("--reset")
  system! "bin/rails dispute:prepare_redis"

  puts "\n== Removing old logs and tempfiles =="
  system! "bin/rails log:clear tmp:clear"

  puts "\n== Checking Redis =="
  if command_exists?("redis-server")
    puts "Redis is installed ✅"
  else
    puts "⚠️  Redis not found. Install it before running Sidekiq."
  end

  unless ARGV.include?("--skip-server")
    puts "\n== Starting development server =="
    STDOUT.flush # flush the output before exec(2) so that it displays
    exec "bin/dev"
  end
end
