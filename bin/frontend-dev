#!/usr/bin/env sh

set -eu

API_HOST="${API_HOST:-127.0.0.1}"
API_PORT="${API_PORT:-3000}"
FRONTEND_PORT="${FRONTEND_PORT:-4000}"
REDIS_HOST="${REDIS_HOST:-127.0.0.1}"
REDIS_PORT="${REDIS_PORT:-6379}"

wait_for_port() {
  host="$1"
  port="$2"
  label="$3"

  echo "Waiting for $label on $host:$port..."

  while ! ruby -rsocket -e "socket = TCPSocket.new(ARGV[0], Integer(ARGV[1])); socket.close" "$host" "$port" >/dev/null 2>&1
  do
    sleep 1
  done
}

wait_for_http() {
  url="$1"
  label="$2"

  echo "Waiting for $label at $url..."

  while ! curl --silent --fail --output /dev/null "$url"
  do
    sleep 1
  done
}

wait_for_port "$REDIS_HOST" "$REDIS_PORT" "Redis"
wait_for_http "http://$API_HOST:$API_PORT/up" "Rails"
wait_for_http "http://$API_HOST:$API_PORT/api/v1/lookups" "Payroll API"

exec npm --prefix payroll-web run dev -- --port "$FRONTEND_PORT" --host --open
